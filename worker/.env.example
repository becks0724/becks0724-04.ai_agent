# worker (Python) 환경변수 템플릿. 실제 값은 로컬 .env 또는 Railway 대시보드에만 둔다.
#
# 규칙:
#  - 여기 있는 키는 절대 프론트엔드 번들로 전달하지 않는다.
#  - 거래소 API 키는 반드시 "읽기 전용" 키만 등록한다. 주문/출금 권한 키는 금지.

WORKER_ENV=local

# Supabase — service_role(또는 secret) 키는 RLS 우회 권한이 있으므로 worker 전용
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 거래소 시세 API (예시) — 공개 엔드포인트만 쓸 경우 비워둬도 됨
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# COINGECKO_API_KEY=

# 뉴스
# CRYPTOPANIC_API_KEY=

# LLM (Stage 4)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# 시세 폴링 (Stage 1)
POLL_INTERVAL_SECONDS=30
POLL_SYMBOLS=BTC,ETH,SOL
